<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_rounded_green_transparent"
    android:orientation="vertical"
    android:clipToOutline="true">

    <!-- Face Placeholder (Top) -->
    <ImageView
        android:id="@+id/img_face"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        android:layout_gravity="center_horizontal"
        android:scaleType="fitCenter"
        android:layout_marginBottom="4dp"
        android:src="@drawable/face_happy"
        android:contentDescription="Face" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="115dp"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="11dp">

        <!-- Title -->
        <TextView
            android:id="@+id/txt_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My stats"
            android:textSize="15sp"
            android:fontFamily="@font/cabinet_grotesk_extrabold"
            android:textColor="@color/zen_text_primary"
            android:layout_marginBottom="4dp" />

        <!-- Stats Row 1 Headers -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Screen Time"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/bricolage_grotesque_semi_bold"
                android:textColor="@color/zen_text_primary" />
                
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Unlocks"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/bricolage_grotesque_semi_bold"
                android:textColor="@color/zen_text_primary"/>
        </LinearLayout>

        <!-- Stats Row 1 Values -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/txt_screen_time"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="66"
                    android:textSize="25sp"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="20sp"
                    app:autoSizeMaxTextSize="32sp"
                    app:autoSizeStepGranularity="2sp"
                    android:fontFamily="@font/reddit_mono_600_normal"
                    android:textColor="@color/zen_text_primary"
                    android:gravity="bottom" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mins"
                    android:textSize="9sp"
                    android:layout_gravity="bottom"
                    android:paddingBottom="6dp"
                    android:fontFamily="@font/reddit_mono_600_normal"
                    android:textColor="@color/zen_text_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/txt_unlocks"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="60"
                    android:textSize="25sp"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="20sp"
                    app:autoSizeMaxTextSize="32sp"
                    app:autoSizeStepGranularity="2sp"
                    android:fontFamily="@font/reddit_mono_600_normal"
                    android:textColor="@color/zen_text_primary" 
                    android:gravity="bottom"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="times"
                    android:textSize="9sp"
                    android:layout_gravity="bottom"
                    android:paddingBottom="6dp"
                    android:fontFamily="@font/reddit_mono_600_normal"
                    android:textColor="@color/zen_text_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mindfulness -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mindfulness"
                android:textSize="12sp"
                android:fontFamily="@font/cabinet_grotesk_bold"
                android:textColor="@color/zen_text_primary"
                android:layout_marginEnd="8dp"/>
                
            <com.zenlauncher.zenmode.SegmentedProgressBar
                android:id="@+id/progress_mindfulness"
                android:layout_width="match_parent"
                android:layout_height="12dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
