<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="48dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Default Launcher"
        android:fontFamily="@font/cabinet_grotesk_bold"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your mindful home screen"
        android:fontFamily="@font/cabinet_grotesk_bold"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"/>

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_default_launcher"
        app:tint="@color/black"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintBottom_toTopOf="@id/tv_section_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_section_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Make ZenMode your home"
        android:fontFamily="@font/cabinet_grotesk_bold"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@id/tv_description"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set ZenMode as your default launcher to start every session with intention."
        android:fontFamily="@font/cabinet_grotesk_bold"
        android:layout_marginBottom="32dp"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@id/btn_set_default_launcher"/>

    <Button
        android:id="@+id/btn_set_default_launcher"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_black_rounded"
        android:text="Set Default Launcher"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="@font/cabinet_grotesk_bold"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="parent"
        android:stateListAnimator="@null" />

</androidx.constraintlayout.widget.ConstraintLayout>
