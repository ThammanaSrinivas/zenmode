<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/zen_beige">

    <!-- Background Logo -->
    <ImageView
        android:layout_width="520dp"
        android:layout_height="520dp"
        android:src="@drawable/app_icon"
        android:alpha="0.07"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="-36dp"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Top Bar -->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_launcher_foreground" 
        android:layout_margin="24dp"
        app:tint="@color/zen_text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:visibility="invisible"/> <!-- Hidden for now as per flow -->

    <LinearLayout
        android:id="@+id/onboarding_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="24dp"
        android:gravity="center">
        
       <ImageView
           android:id="@+id/iv_header_logo"
           android:layout_width="120dp"
           android:layout_height="30dp"
           android:src="@drawable/logo_png" 
           android:adjustViewBounds="true"
           android:scaleType="fitCenter"/>

        <ProgressBar
            android:id="@+id/pb_header"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="50"
            android:progressDrawable="@drawable/bg_rounded_green_progress" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_page_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1/2"
        android:fontFamily="@font/cabinet_grotesk"
        android:background="@drawable/bg_rounded_item"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_page_indicator"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
